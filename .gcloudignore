# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore, with the addition of
# "#!include" directives (which insert the entries of the given .gitignore-style
# file at that point).

.gcloudignore
.git
.gitignore
.github/
.vscode/
.idea/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.git
.mypy_cache
.pytest_cache
.hypothesis
htmlcov/
.env
.env.*
!.env.example

# Development files
tests/
docs/
scripts/
*.md
!README.md
LICENSE
Makefile
docker-compose*.yml
Dockerfile.test
.dockerignore

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Python notebooks
*.ipynb
.ipynb_checkpoints/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# Build artifacts
dist/
build/
*.egg-info/

# Local development
.env.local
.env.development
debug_*.py
run_tests.py

# Documentation
docs/
*.rst
CONTRIBUTING.md
CHANGELOG.md

# Kubernetes manifests (not needed for Cloud Run)
k8s/
kubernetes/

# Local scripts
gcp/
scripts/

# Cache directories
.claude/