"""
Test planetary position accuracy against known ephemeris data.
"""
import pytest
from datetime import datetime
import pytz
from josi.services.astrology import AstrologyCalculator
from josi.services.validation import AstrologyValidator


class TestPlanetaryAccuracy:
    """
    Test astronomical calculations against known accurate values.
    """
    
    @pytest.fixture
    def calculator(self):
        return AstrologyCalculator()
    
    @pytest.fixture
    def validator(self):
        return AstrologyValidator()
    
    def test_sun_position_j2000(self, calculator, validator):
        """
        Test Sun position at J2000.0 epoch (2000-01-01 12:00 UTC)
        Expected values from NASA JPL Horizons
        """
        # J2000.0 epoch
        dt = datetime(2000, 1, 1, 12, 0, 0, tzinfo=pytz.UTC)
        
        # Greenwich coordinates
        latitude = 51.4779
        longitude = 0.0
        
        # Calculate
        chart = calculator.calculate_western_chart(dt, latitude, longitude)
        sun = chart['planets']['Sun']
        
        # Expected values (from JPL Horizons)
        expected = {
            'longitude': 280.6417,  # degrees
            'latitude': 0.0,        # degrees (Sun always near ecliptic)
            'speed': 1.0194        # degrees/day
        }
        
        # Validate
        validation = validator.validate_planet_position(sun, expected)
        assert validation['valid'], f"Sun position validation failed: {validation}"
    
    def test_moon_position_known_date(self, calculator, validator):
        """
        Test Moon position on a known date
        Moon moves fast (~13°/day) so it's a good accuracy test
        """
        # Test date: 2023-07-20 00:00 UTC
        dt = datetime(2023, 7, 20, 0, 0, 0, tzinfo=pytz.UTC)
        
        # Greenwich coordinates
        latitude = 51.4779
        longitude = 0.0
        
        # Calculate
        chart = calculator.calculate_western_chart(dt, latitude, longitude)
        moon = chart['planets']['Moon']
        
        # Expected approximate values
        expected = {
            'longitude': 155.5,  # Leo
            'speed': 13.2       # degrees/day
        }
        
        # Moon tolerance is higher due to rapid movement
        validator.tolerance['longitude'] = 0.5
        validation = validator.validate_planet_position(moon, expected)
        
        # Reset tolerance
        validator.tolerance['longitude'] = 0.01
    
    def test_ayanamsa_lahiri(self, calculator, validator):
        """
        Test Lahiri ayanamsa calculation
        """
        dt = datetime(2024, 1, 1, 0, 0, 0, tzinfo=pytz.UTC)
        
        # Calculate
        julian_day = calculator._datetime_to_julian(dt)
        ayanamsa = calculator._get_ayanamsa(julian_day, 'lahiri')
        
        # Validate
        validation = validator.validate_ayanamsa(ayanamsa, 'lahiri', dt)
        assert validation['valid'], f"Ayanamsa validation failed: {validation}"
    
    def test_retrograde_detection(self, calculator):
        """
        Test retrograde planet detection (negative speed)
        """
        # Date when Mercury was retrograde
        dt = datetime(2023, 8, 23, 0, 0, 0, tzinfo=pytz.UTC)
        
        latitude = 40.7128  # New York
        longitude = -74.0060
        
        chart = calculator.calculate_western_chart(dt, latitude, longitude)
        mercury = chart['planets']['Mercury']
        
        # During retrograde, speed should be negative
        assert mercury['speed'] < 0, "Mercury should show retrograde motion"
    
    def test_house_calculation_accuracy(self, calculator):
        """
        Test house cusp calculations
        """
        dt = datetime(2023, 6, 21, 12, 0, 0, tzinfo=pytz.UTC)  # Summer solstice
        
        # Test at different latitudes
        test_locations = [
            (0.0, 0.0),      # Equator
            (23.5, 0.0),     # Tropic of Cancer
            (51.5, 0.0),     # London latitude
            (90.0, 0.0),     # North Pole (edge case)
        ]
        
        for lat, lon in test_locations:
            if abs(lat) < 89:  # Skip poles for house calculations
                houses = calculator._calculate_houses(
                    calculator._datetime_to_julian(dt), lat, lon
                )
                
                # Basic sanity checks
                assert len(houses) == 12, "Should have 12 house cusps"
                assert houses[0] >= 0 and houses[0] < 360, "Ascendant out of range"
                
                # Check house sizes are reasonable (not 0 or 360)
                for i in range(12):
                    size = (houses[(i+1)%12] - houses[i]) % 360
                    assert 10 < size < 60, f"House {i+1} size unreasonable: {size}°"


class TestValidationData:
    """
    Test data validation against multiple sources.
    """
    
    def test_ephemeris_comparison(self):
        """
        Compare Swiss Ephemeris output with known accurate values.
        This test would run against a dataset of verified positions.
        """
        # Test dataset (simplified example)
        test_data = [
            {
                'date': '2000-01-01T12:00:00Z',
                'planet': 'Jupiter',
                'expected_longitude': 25.1234,  # Aries
                'tolerance': 0.01
            },
            {
                'date': '2020-12-21T00:00:00Z',  # Great Conjunction
                'planet': 'Jupiter',
                'expected_longitude': 300.5678,  # Aquarius
                'tolerance': 0.01
            },
            {
                'date': '2020-12-21T00:00:00Z',
                'planet': 'Saturn',
                'expected_longitude': 300.5690,  # Very close to Jupiter
                'tolerance': 0.01
            }
        ]
        
        calculator = AstrologyCalculator()
        
        for test in test_data:
            dt = datetime.fromisoformat(test['date'].replace('Z', '+00:00'))
            chart = calculator.calculate_western_chart(dt, 0.0, 0.0)
            
            actual = chart['planets'][test['planet']]['longitude']
            expected = test['expected_longitude']
            diff = abs(actual - expected)
            
            if diff > 180:
                diff = 360 - diff
            
            assert diff <= test['tolerance'], (
                f"{test['planet']} on {test['date']}: "
                f"expected {expected}°, got {actual}°, diff {diff}°"
            )


# Benchmark tests for accuracy improvements
class TestAccuracyImprovements:
    """
    Test high-precision corrections and improvements.
    """
    
    def test_aberration_correction(self):
        """
        Test aberration of light correction.
        """
        from josi.services.validation import AccuracyImprover
        
        # Test correction
        longitude = 100.0
        speed = 1.0
        
        corrected = AccuracyImprover.apply_aberration_correction(longitude, speed)
        
        # Should apply small correction
        assert abs(corrected - longitude) < 0.01
        assert corrected != longitude
    
    def test_topocentric_moon(self):
        """
        Test topocentric correction for Moon (important due to parallax).
        """
        from josi.services.validation import AccuracyImprover
        
        geocentric = {
            'longitude': 180.0,
            'latitude': 5.0,
            'distance': 384400  # km, average Moon distance
        }
        
        # Observer at 45°N
        topocentric = AccuracyImprover.calculate_topocentric_position(
            geocentric, 45.0, 0.0
        )
        
        # Should show parallax shift
        assert topocentric['longitude'] != geocentric['longitude']