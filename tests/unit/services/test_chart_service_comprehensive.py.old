    @pytest.mark.asyncio
    async def test_create_progressed_chart(self, chart_service, mock_dependencies, test_person):
        """Test creating a progressed chart."""
        progression_date = datetime(2024, 1, 1)
        
        mock_dependencies['person_repository'].get.return_value = test_person
        
        # Mock progression calculation
        with patch('josi.services.chart_service.ProgressionsCalculator') as mock_prog:
            mock_prog_instance = MagicMock()
