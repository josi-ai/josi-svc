                'progressed_planets': {'Sun': {'longitude': 310.0}}
            }
            
            mock_dependencies['chart_repository'].create.return_value = MagicMock(chart_id='prog123')
            
            result = await chart_service.create_progressed_chart(
                person_id=test_person['person_id'],
                progression_date=progression_date,
                progression_type='secondary',
                astrology_system=AstrologySystem.WESTERN,
                organization_id=mock_dependencies['organization_id']
            )
            
            assert result.chart_id == 'prog123'
            assert result.chart_type == ChartType.PROGRESSED
    
    @pytest.mark.asyncio
    async def test_calculate_compatibility(self, chart_service, mock_dependencies):
        """Test compatibility calculation between two charts."""
        chart1_data = {
            'planets': {'Sun': {'longitude': 100.0}, 'Moon': {'longitude': 200.0}},
            'ascendant': {'longitude': 0.0}
        }
        chart2_data = {
            'planets': {'Sun': {'longitude': 280.0}, 'Moon': {'longitude': 20.0}},
            'ascendant': {'longitude': 180.0}
        }
        
        compatibility = await chart_service.calculate_compatibility(
            chart1_data, chart2_data, AstrologySystem.VEDIC
        )
        
        assert 'overall_score' in compatibility
        assert 'aspects' in compatibility
        assert 'strengths' in compatibility
        assert 'challenges' in compatibility
    
    @pytest.mark.asyncio
    async def test_batch_create_charts(self, chart_service, mock_dependencies, test_person):
        """Test batch creation of multiple charts."""
        mock_dependencies['person_repository'].get.return_value = test_person
        mock_dependencies['astrology_calculator'].calculate_vedic_chart.return_value = {
            'planets': {}
        }
        mock_dependencies['interpretation_engine'].generate_interpretations.return_value = {}
        mock_dependencies['chart_repository'].create.side_effect = [
            MagicMock(chart_id='1'),
            MagicMock(chart_id='2'),
            MagicMock(chart_id='3')
        ]
        
        systems = [AstrologySystem.VEDIC, AstrologySystem.WESTERN, AstrologySystem.CHINESE]
        
        results = await chart_service.batch_create_charts(
            person_id=test_person['person_id'],
            chart_type=ChartType.NATAL,
            astrology_systems=systems,
            organization_id=mock_dependencies['organization_id']
        )
        
        assert len(results) == 3
        assert mock_dependencies['chart_repository'].create.call_count == 3
    
    def test_calculate_aspect(self, chart_service):
        """Test aspect calculation between planets."""
        planet1_longitude = 100.0
        planet2_longitude = 190.0
        
        aspect = chart_service._calculate_aspect(planet1_longitude, planet2_longitude)
        
        assert aspect is not None
        assert aspect['angle'] == 90.0
        assert aspect['type'] == 'square'
        assert 'orb' in aspect
    
    def test_get_house_position(self, chart_service):
        """Test house position calculation."""
        houses = [0, 30, 60, 90, 120, 150, 180, 210, 240, 270, 300, 330]
        planet_longitude = 45.0
        
        house = chart_service._get_house_position(planet_longitude, houses)
        
        assert house == 2  # 45° is in 2nd house (30-60°)
    
    @pytest.mark.asyncio
    async def test_error_handling_person_not_found(self, chart_service, mock_dependencies):
        """Test error handling when person not found."""
        mock_dependencies['person_repository'].get.return_value = None
        
        with pytest.raises(ValueError, match="Person not found"):
            await chart_service.create_chart(
                person_id=str(uuid4()),
                chart_type=ChartType.NATAL,
                astrology_system=AstrologySystem.VEDIC,
                organization_id=mock_dependencies['organization_id']
            )
    
    @pytest.mark.asyncio
    async def test_chart_caching(self, chart_service, mock_dependencies, test_person, test_chart):
        """Test chart caching functionality."""
        mock_dependencies['person_repository'].get.return_value = test_person
        mock_dependencies['chart_repository'].get_recent_by_type.return_value = test_chart
        
        # Should return cached chart
        result = await chart_service.create_chart(
            person_id=test_person['person_id'],
            chart_type=ChartType.NATAL,
            astrology_system=AstrologySystem.VEDIC,
            organization_id=mock_dependencies['organization_id'],
            use_cache=True
        )
        
        assert result == test_chart
        # Should not create new chart
        mock_dependencies['chart_repository'].create.assert_not_called()