    @pytest.mark.asyncio
    async def test_list_charts_with_pagination(self, chart_service, mock_chart_repository, test_chart):
        """Test listing charts with specific pagination parameters."""
        charts = [test_chart] * 5
        skip = 10
        limit = 20
        
        mock_chart_repository.get_multi.return_value = charts
        
        result = await chart_service.list_charts(skip=skip, limit=limit)
        
        assert result == charts
        assert len(result) == 5
        mock_chart_repository.get_multi.assert_called_once_with(skip=skip, limit=limit)
    
