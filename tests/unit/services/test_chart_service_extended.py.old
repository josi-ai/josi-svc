                    chart_types=chart_types
                )
    
    @pytest.mark.asyncio
    async def test_interpretation_error_handling(self, chart_service, test_chart_id, test_chart, mock_chart_repository, mock_interpretation_engine):
        """Test error handling during interpretation generation."""
        interpretation_types = ["general"]
        language = "en"
        
        mock_chart_repository.get.return_value = test_chart
        mock_interpretation_engine.generate_interpretation.side_effect = Exception("Interpretation service error")
        
        with pytest.raises(Exception, match="Interpretation service error"):
            await chart_service.generate_interpretations(
                chart_id=test_chart_id,
                interpretation_types=interpretation_types,
                language=language
            )
    
    @pytest.mark.asyncio
    async def test_service_initialization_with_dependencies(self, mock_db_session):
        """Test ChartService initialization with all dependencies."""
        org_id = uuid4()
        
        with patch('josi.services.chart_service.ChartRepository') as mock_repo_class:
            with patch('josi.services.chart_service.AstrologyCalculator') as mock_calc_class:
                with patch('josi.services.chart_service.InterpretationEngine') as mock_interp_class:
                    service = ChartService(mock_db_session, org_id)
                    
                    # Verify dependencies were initialized
                    mock_repo_class.assert_called_once_with(AstrologyChart, mock_db_session, org_id)
                    mock_calc_class.assert_called_once()
                    mock_interp_class.assert_called_once()
                    
                    assert service.db == mock_db_session
                    assert service.organization_id == org_id
                    assert hasattr(service, 'chart_repository')
                    assert hasattr(service, 'astrology_calculator')
                    assert hasattr(service, 'interpretation_engine')
    
    @pytest.mark.asyncio
    async def test_chart_data_structure_after_calculation(self, chart_service, test_person, mock_astrology_calculator):
        """Test that calculated chart data has expected structure."""
        chart_type = "natal"
        
        with patch.object(chart_service, '_get_person_for_calculation', return_value=test_person):
            result = await chart_service._calculate_single_chart(
                person_id=test_person.person_id,
                chart_type=chart_type
            )
        
        # Verify chart data structure
        assert isinstance(result.chart_data, dict)
        assert result.calculated_at is not None
        assert result.calculation_version is not None
        assert result.chart_type == chart_type
    
