    @pytest.mark.asyncio
    async def test_update_chart_with_valid_data(self, chart_service, mock_chart_repository, test_chart_id, test_chart):
        """Test updating a chart with valid data."""
        update_data = {
            "chart_type": "transit",
            "house_system": "koch",
            "chart_data": {"updated": True}
        }
        
        updated_chart = test_chart
        updated_chart.chart_type = "transit"
        updated_chart.house_system = "koch"
        
        mock_chart_repository.update.return_value = updated_chart
        
        result = await chart_service.update_chart(test_chart_id, update_data)
        
        assert result == updated_chart
        mock_chart_repository.update.assert_called_once_with(test_chart_id, update_data)
    
    @pytest.mark.asyncio
    async def test_generate_interpretations_multiple_types(self, chart_service, test_chart_id, test_chart, mock_chart_repository, mock_interpretation_engine):
        """Test generating multiple interpretation types for a chart."""
        interpretation_types = ["general", "personality", "career"]
        language = "en"
        
        mock_chart_repository.get.return_value = test_chart
        
        expected_interpretations = []
        for interp_type in interpretation_types:
            expected_interpretations.append({
                "interpretation_type": interp_type,
                "text": f"Test {interp_type} interpretation",
                "confidence": 0.85,
                "language": language
            })
        
        mock_interpretation_engine.generate_interpretation.side_effect = expected_interpretations
        
        result = await chart_service.generate_interpretations(
            chart_id=test_chart_id,
            interpretation_types=interpretation_types,
            language=language
        )
        
        assert len(result) == 3
        assert mock_interpretation_engine.generate_interpretation.call_count == 3
        for i, interpretation in enumerate(result):
            assert interpretation["interpretation_type"] == interpretation_types[i]
    
    @pytest.mark.asyncio
    async def test_generate_interpretations_different_language(self, chart_service, test_chart_id, test_chart, mock_chart_repository, mock_interpretation_engine):
        """Test generating interpretations in different language."""
        interpretation_types = ["general"]
        language = "es"
        
        mock_chart_repository.get.return_value = test_chart
        mock_interpretation_engine.generate_interpretation.return_value = {
            "interpretation_type": "general",
            "text": "Interpretación de prueba",
            "confidence": 0.85,
            "language": "es"
        }
        
        result = await chart_service.generate_interpretations(
            chart_id=test_chart_id,
            interpretation_types=interpretation_types,
            language=language
        )
        
        assert len(result) == 1
        assert result[0]["language"] == "es"
        assert "Interpretación" in result[0]["text"]
    
    @pytest.mark.asyncio
    async def test_get_person_for_calculation_success(self, chart_service, test_person):
        """Test successfully getting person for calculation."""
        with patch('josi.services.chart_service.PersonService') as mock_person_service_class:
            mock_person_service = AsyncMock()
            mock_person_service.get_person.return_value = test_person
            mock_person_service_class.return_value = mock_person_service
            
            result = await chart_service._get_person_for_calculation(test_person.person_id)
        
        assert result == test_person
        mock_person_service.get_person.assert_called_once_with(test_person.person_id)
    
    @pytest.mark.asyncio
    async def test_get_person_for_calculation_not_found(self, chart_service, test_person_id):
        """Test getting person for calculation when person not found."""
        with patch('josi.services.chart_service.PersonService') as mock_person_service_class:
            mock_person_service = AsyncMock()
            mock_person_service.get_person.return_value = None
            mock_person_service_class.return_value = mock_person_service
            
            with pytest.raises(ValueError, match="Person not found"):
                await chart_service._get_person_for_calculation(test_person_id)
    
    @pytest.mark.asyncio
    async def test_calculate_single_chart_vedic_system(self, chart_service, test_person, test_organization_id, mock_astrology_calculator):
        """Test calculating a single vedic chart."""
        chart_type = "vedic"
        house_system = "whole_sign"
        ayanamsa = "lahiri"
        
        with patch.object(chart_service, '_get_person_for_calculation', return_value=test_person):
            result = await chart_service._calculate_single_chart(
                person_id=test_person.person_id,
                chart_type=chart_type,
                house_system=house_system,
                ayanamsa=ayanamsa
            )
        
        assert result.chart_type == chart_type
        assert result.house_system == house_system
        assert result.ayanamsa == ayanamsa
        assert result.person_id == test_person.person_id
        assert result.organization_id == test_organization_id
        mock_astrology_calculator.calculate_vedic_chart.assert_called_once()
    
