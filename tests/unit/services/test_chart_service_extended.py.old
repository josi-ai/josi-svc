    @pytest.fixture
    def test_chart(self, test_chart_id, test_person_id, test_organization_id):
        """Create a test chart."""
        return AstrologyChart(
            chart_id=test_chart_id,
            person_id=test_person_id,
            organization_id=test_organization_id,
            chart_type="natal",
            house_system="placidus",
            ayanamsa="lahiri",
            calculated_at=datetime.now(),
            calculation_version="1.0",
            chart_data={"planets": {}, "houses": {}}
        )
    
    @pytest.mark.asyncio
    async def test_calculate_charts_for_person_vedic_system(self, chart_service, mock_chart_repository, test_person_id, mock_astrology_calculator):
        """Test calculating vedic charts for a person."""
        chart_types = ["vedic"]
        house_system = "whole_sign"
        ayanamsa = "lahiri"
        
        expected_chart = AstrologyChart(
            chart_id=uuid4(),
            person_id=test_person_id,
            organization_id=uuid4(),
            chart_type="vedic",
            house_system=house_system,
            ayanamsa=ayanamsa,
            calculated_at=datetime.now(),
            calculation_version="1.0",
            chart_data={"chart_type": "vedic"}
        )
        
        mock_chart_repository.create.return_value = expected_chart
        
        with patch.object(chart_service, '_calculate_single_chart', return_value=expected_chart) as mock_calc:
            result = await chart_service.calculate_charts_for_person(
                person_id=test_person_id,
                chart_types=chart_types,
                house_system=house_system,
                ayanamsa=ayanamsa
            )
        
        assert len(result) == 1
        assert result[0].chart_type == "vedic"
        assert result[0].house_system == house_system
        assert result[0].ayanamsa == ayanamsa
        mock_calc.assert_called_once()
    
