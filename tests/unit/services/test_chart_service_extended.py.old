"""Extended comprehensive unit tests for ChartService to increase coverage."""
import pytest
from unittest.mock import AsyncMock, MagicMock, patch
from uuid import uuid4
from datetime import datetime, date
from decimal import Decimal

from josi.services.chart_service import ChartService
from josi.models.chart_model import AstrologyChart, ChartEntity
from josi.models.person_model import Person
from josi.repositories.base_repository import BaseRepository


class TestChartServiceExtended:
    """Extended comprehensive test coverage for ChartService."""
    
    @pytest.fixture
    def mock_chart_repository(self):
        """Create a mock chart repository."""
        repo = AsyncMock(spec=BaseRepository)
        return repo
    
    @pytest.fixture
    def mock_astrology_calculator(self):
        """Create a mock astrology calculator."""
        calculator = MagicMock()
        calculator.calculate_planetary_positions = MagicMock(return_value={
            "sun": {"longitude": 120.5, "sign": "leo", "house": 5},
            "moon": {"longitude": 45.2, "sign": "taurus", "house": 1}
        })
        calculator.calculate_house_cusps = MagicMock(return_value={
            "1": 0.0, "2": 30.0, "3": 60.0, "4": 90.0,
            "5": 120.0, "6": 150.0, "7": 180.0, "8": 210.0,
            "9": 240.0, "10": 270.0, "11": 300.0, "12": 330.0
        })
        calculator.calculate_aspects = MagicMock(return_value=[
            {"planet1": "sun", "planet2": "moon", "aspect": "trine", "orb": 2.3}
        ])
        calculator.calculate_vedic_chart = MagicMock(return_value={"chart_type": "vedic"})
        calculator.calculate_western_chart = MagicMock(return_value={"chart_type": "western"})
        calculator.calculate_chinese_chart = MagicMock(return_value={"chart_type": "chinese"})
        calculator.calculate_divisional_chart = MagicMock(return_value={"chart_type": "divisional"})
        return calculator
    
    @pytest.fixture
    def mock_interpretation_engine(self):
        """Create a mock interpretation engine."""
        engine = MagicMock()
        engine.generate_interpretation = MagicMock(return_value={
            "interpretation_type": "general",
            "text": "This is a test interpretation",
            "confidence": 0.85,
            "language": "en"
        })
        return engine
    
    @pytest.fixture
    def mock_db_session(self):
        """Create a mock database session."""
        return AsyncMock()
    
    @pytest.fixture
    def chart_service(self, mock_db_session, mock_chart_repository, mock_astrology_calculator, mock_interpretation_engine):
        """Create a ChartService instance."""
        with patch('josi.services.chart_service.ChartRepository', return_value=mock_chart_repository):
            with patch('josi.services.chart_service.AstrologyCalculator', return_value=mock_astrology_calculator):
                with patch('josi.services.chart_service.InterpretationEngine', return_value=mock_interpretation_engine):
                    service = ChartService(mock_db_session, uuid4())
                    return service
    
