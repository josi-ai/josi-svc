    @pytest.mark.asyncio
    async def test_calculate_charts_with_multiple_systems(self, chart_service, mock_chart_repository, test_person_id):
        """Test calculating multiple chart systems at once."""
        chart_types = ["vedic", "western", "chinese"]
        expected_charts = []
        
        for i, chart_type in enumerate(chart_types):
            chart = AstrologyChart(
                chart_id=uuid4(),
                person_id=test_person_id,
                organization_id=uuid4(),
                chart_type=chart_type,
                house_system="placidus",
                calculated_at=datetime.now(),
                calculation_version="1.0",
                chart_data={f"chart_type": chart_type}
            )
            expected_charts.append(chart)
        
        mock_chart_repository.create.side_effect = expected_charts
        
        with patch.object(chart_service, '_calculate_single_chart', side_effect=expected_charts) as mock_calc:
            result = await chart_service.calculate_charts_for_person(
                person_id=test_person_id,
                chart_types=chart_types
            )
        
        assert len(result) == 3
        assert mock_calc.call_count == 3
        for i, chart in enumerate(result):
            assert chart.chart_type == chart_types[i]
    
    @pytest.mark.asyncio
    async def test_calculate_charts_with_interpretations_enabled(self, chart_service, mock_chart_repository, mock_interpretation_engine, test_person_id):
        """Test calculating charts with interpretations enabled."""
        chart_types = ["natal"]
        expected_chart = AstrologyChart(
            chart_id=uuid4(),
            person_id=test_person_id,
            organization_id=uuid4(),
            chart_type="natal",
            calculated_at=datetime.now(),
            calculation_version="1.0",
            chart_data={"planets": {}, "interpretations": []}
        )
        
        mock_chart_repository.create.return_value = expected_chart
        
        with patch.object(chart_service, '_calculate_single_chart', return_value=expected_chart) as mock_calc:
            with patch.object(chart_service, '_add_interpretations_to_chart') as mock_interp:
                result = await chart_service.calculate_charts_for_person(
                    person_id=test_person_id,
                    chart_types=chart_types,
                    include_interpretations=True
                )
        
        assert len(result) == 1
        mock_calc.assert_called_once()
        mock_interp.assert_called_once()
    
    @pytest.mark.asyncio
    async def test_get_person_charts_with_chart_type_filter(self, chart_service, mock_chart_repository, test_person_id, test_chart):
