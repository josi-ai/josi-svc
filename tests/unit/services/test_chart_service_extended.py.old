    def test_organization_id(self):
        """Test organization ID."""
        return uuid4()
    
    @pytest.fixture
    def test_person_id(self):
        """Test person ID."""
        return uuid4()
    
    @pytest.fixture
    def test_chart_id(self):
        """Test chart ID."""
        return uuid4()
    
    @pytest.fixture
